generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Encrypted credentials (AES-256-GCM JSON blobs)
  notionCredentials    String? // {accessToken, workspaceId}
  wordpressCredentials String? // {siteUrl, username, appPassword}

  // Notion config
  notionAuthMode      String?   // "internal" | "oauth"
  notionWorkspaceId   String?
  notionDatabaseId    String?
  notionTriggerStatus String @default("Post to Wordpress")
  notionPublishTriggerStatus String @default("Publish")
  notionUpdateTriggerStatus  String @default("Update Wordpress")

  // WordPress config
  wpSiteUrl       String?
  wpSeoPlugin     String?         // Detected SEO plugin: "rankmath", "seopress", or null
  codeHighlighter    CodeHighlighter    @default(PRISMATIC)
  featuredImageMode  FeaturedImageMode  @default(STANDARD)
  aiImageStyle       String?

  // Notifications
  webhookUrl              String?
  onboardingEmailSentAt   DateTime?
  trialExpiryEmailSentAt  DateTime?

  // Billing
  plan                 Plan      @default(TRIAL)
  trialEndsAt          DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  users      User[]
  posts      Post[]
  categories Category[]
  tags       Tag[]
  imageCache ImageMapping[]
  jobs       Job[]

  @@index([notionWorkspaceId])
  @@map("tenants")
}

enum Plan {
  FREE
  PRO
  TRIAL
}

enum CodeHighlighter {
  PRISMATIC
  WP_CODE
  HIGHLIGHT_JS
  PRISM_JS
}

enum FeaturedImageMode {
  STANDARD
  AI_GENERATED
}

model User {
  id       String   @id @default(cuid())
  email    String
  name     String?
  role     UserRole @default(MEMBER)
  apiKey   String?  @unique
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  passwordHash  String?
  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Post {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Notion source
  notionPageId   String?
  notionLastEdit DateTime?

  // Content
  title           String
  slug            String?
  markdownContent String? @db.Text
  wpContent       String? @db.Text
  excerpt         String? @db.Text

  // WordPress target
  wpPostId Int?
  wpUrl    String?

  // SEO
  seoKeyword     String?
  seoDescription String?

  // Taxonomy
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tags       String[]

  // Featured image
  featuredImageTitle String?
  featuredImageUrl   String?
  wpFeaturedMediaId  Int?

  // Status tracking
  status      PostStatus @default(SYNCED)
  syncedAt    DateTime?
  publishedAt DateTime?

  imageMappings ImageMapping[]
  jobs          Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, notionPageId])
  @@index([tenantId, status])
  @@map("posts")
}

enum PostStatus {
  SYNCED
  IMAGES_PROCESSING
  PUBLISHING
  PUBLISHED
  UPDATE_PENDING
  FAILED
}

model Category {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  wpCategoryId    Int?
  wpTagIds        Int[]
  backgroundImage String?

  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("categories")
}

model Tag {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  wpTagId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("tags")
}

model ImageMapping {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  notionImageUrl String
  wpImageUrl     String
  wpMediaId      Int
  filename       String?

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([tenantId, notionImageUrl])
  @@index([tenantId, postId])
  @@map("image_mappings")
}

model Job {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  attempts    Int       @default(0)
  pgBossJobId String?

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([tenantId, status])
  @@index([type, status])
  @@map("jobs")
}

enum JobType {
  NOTION_POLL
  SYNC_POST
  PROCESS_IMAGES
  GENERATE_FEATURED_IMAGE
  PUBLISH_POST
  UPDATE_POST
  IMPORT_POST
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
