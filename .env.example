# Connection string for PostgreSQL (local dev only)
# On VPS setup this is overridden by docker-compose.yml using DB_PASSWORD and host "postgres"
DATABASE_URL=postgresql://notipo:localdev@localhost:5432/notipo

# Secret key used to encrypt stored Notion and WordPress credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Admin API key — protects /api/admin/* routes (manage tenants, impersonate users).
# Required even for single-tenant setups; secures admin endpoints.
# Generate with: openssl rand -hex 16
API_KEY=change-me-in-production

PORT=3000
LOG_LEVEL=info

# ─── Self-service signup ──────────────────────────────────────────────────────
# Set to true to allow open registration (multi-tenant SaaS mode).
# When false, only the first user can register (single-tenant self-hosted mode).
ALLOW_SIGNUP=false

# ─── Notion OAuth (optional, for public/external integration) ────────────────
# Register a public integration at https://www.notion.so/my-integrations
# Set the redirect URI to {YOUR_DOMAIN}/api/notion/oauth/callback
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/notion/oauth/callback

# ─── Notion webhooks (primary trigger) ───────────────────────────────────────
# Webhooks are configured on the Notion public integration and delivered
# automatically for all OAuth users. Set up a webhook subscription in your
# integration settings pointing to {YOUR_DOMAIN}/api/notion/webhook.
# On first request Notion sends a verification_token — check your app logs and
# paste it here, then verify in the Notion dashboard.
NOTION_WEBHOOK_SECRET=

# ─── Polling (safety net) ────────────────────────────────────────────────────
# Polling runs as a fallback to catch any events missed by webhooks.
# Default: 300 seconds (5 minutes). Set lower for faster fallback detection.
POLL_INTERVAL_SECONDS=300

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Used for email verification and password reset emails. Sign up at https://resend.com
# Verify your domain in Resend Dashboard to send from your own address.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# (Optional) Receive an email when a new user signs up
ADMIN_NOTIFY_EMAIL=

# ─── Stripe billing (optional) ────────────────────────────────────────────────
# Create a Stripe account and set up a Pro product with a $19/mo recurring price.
# Webhook endpoint: {YOUR_DOMAIN}/api/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ─── PostHog analytics (optional) ────────────────────────────────────────────
# Tracks user behavior in the admin UI (onboarding completion, feature usage).
# Sign up at https://posthog.com — the free tier covers 1M events/month.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# ─── Sentry error monitoring (optional) ───────────────────────────────────────
# API: server-side error tracking
SENTRY_DSN=
# Web: browser-side error tracking (exposed to the client)
NEXT_PUBLIC_SENTRY_DSN=

# ─── Unsplash (optional) ─────────────────────────────────────────────────────
# When set, featured images use a relevant Unsplash photo as the background
# instead of a plain gradient. Get a free API key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ─── Gemini AI images (optional) ────────────────────────────────────────────
# When set, enables AI-generated featured images using Google Gemini.
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── VPS / Traefik deployment (docker-compose.yml only) ─────────────────
# Your public domain — must have an A record pointing to the VPS IP
DOMAIN=api.yourdomain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com
# Postgres password used by the postgres container (prod only)
# Generate with: openssl rand -hex 16
DB_PASSWORD=change-me-in-production

# ─── Seed (development only) ─────────────────────────────────────────────────
# Used by `npm run seed -w @notipo/api` during local development.
# In production, register your account through the admin UI instead.
SEED_TENANT_NAME=My Blog
SEED_TENANT_SLUG=myblog
SEED_OWNER_EMAIL=owner@example.com
# Password for the seeded owner — set this to log in with email/password.
# If left blank, the owner can only log in with the API key below.
SEED_OWNER_PASSWORD=
# API key for the seeded owner — also used for API calls.
# If left blank, falls back to API_KEY above.
SEED_API_KEY=

# Notion status value that triggers the publish pipeline
SEED_NOTION_TRIGGER_STATUS=Post to Wordpress
